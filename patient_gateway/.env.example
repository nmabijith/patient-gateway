SECRET_KEY=replace-with-a-long-random-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DB_NAME=patient_gateway
DB_USER=pigw_user
DB_PASSWORD=replace-with-your-actual-password
DB_HOST=localhost
DB_PORT=5432
FIELD_ENCRYPTION_KEY=replace-with-a-fernet-key
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=True
# Email. Use the console backend for local dev (prints to stdout), or the SMTP
# backend to actually send. For Gmail SMTP the password must be a Google
# "App Password" (16 chars), not your normal account password.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=no-reply@patient-gateway.local
REDIS_URL=redis://localhost:6379/1
